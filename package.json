{
  "name": "google-timer-app",
  "version": "1.0.0",
  "description": "화면에 항상 떠있는 미니 비주얼 타이머",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dist:mac": "electron-builder --mac",
    "dist:win": "electron-builder --win zip"
  },
  "devDependencies": {
    "electron": "^31.0.0",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.bunohoq.minitimer",
    "productName": "MiniTimer",
    "files": [
      "main.js",
      "preload.js",
      "index.html",
      "style.css",
      "renderer.js"
    ],
    "directories": {
      "output": "dist"
    },
    "mac": {
      "target": "dmg",
      "category": "public.app-category.productivity"
    },
    "win": {
      "target": "zip"
    }
  }
}
